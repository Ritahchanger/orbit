{
  "name": "orbit_power_backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon ./src/server.js",
    "dev:worker": "nodemon ./src/workers/email.worker.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:worker\"",
    "start": "node ./src/server.js",
    "start:worker": "node ./src/workers/email.worker.js",
    "pm2:dev": "pm2 start ecosystem.config.js --env development",
    "pm2:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart all",
    "pm2:reload": "pm2 reload all",
    "pm2:delete": "pm2 delete all",
    "pm2:logs": "pm2 logs",
    "redis:test": "node src/config/test-redis.js",
    "redis:start": "sudo systemctl start redis-server",
    "redis:stop": "sudo systemctl stop redis-server",
    "redis:status": "sudo systemctl status redis-server",
    "redis:restart": "sudo systemctl restart redis-server",
    "redis:install": "sudo apt update && sudo apt install redis-server -y",
    "redis:cli": "redis-cli",
    "redis:ping": "redis-cli ping",
    "pm2:status": "pm2 status",
    "pm2:monitor": "pm2 monit",
    "pm2:logs:workers": "pm2 logs email-worker",
    "pm2:logs:workers:follow": "pm2 logs email-worker --lines 20 --raw",
    "pm2:logs:workers:error": "pm2 logs email-worker --err --lines 50",
    "pm2:logs:workers:out": "pm2 logs email-worker --out --lines 50",
    "pm2:logs:workers:recent": "pm2 logs email-worker --lines 100 --nostream",
    "pm2:logs:workers:tail": "pm2 logs email-worker --lines 30",
    "pm2:logs:workers:live": "pm2 logs email-worker --raw",
    "pm2:logs:api": "pm2 logs orbit-api",
    "pm2:logs:api:error": "pm2 logs orbit-api --err --lines 50",
    "pm2:logs:api:out": "pm2 logs orbit-api --out --lines 50",
    "pm2:logs:all:error": "pm2 logs --err --lines 50",
    "pm2:logs:all:out": "pm2 logs --out --lines 50",
    "pm2:logs:clean": "pm2 flush",
    "pm2:workers:status": "pm2 info email-worker",
    "pm2:workers:restart": "pm2 restart email-worker",
    "pm2:workers:scale": "pm2 scale email-worker 4",
    "create-superadmin": "node ./src/seeders/admin.seed.js",
    "superadmin:info": "node ./src/seeders/admin.seed.js --info",
    "seed:business": "node ./src/seeders/business.seed.js --info",
    "superadmin:force": "node ./src/seeders/admin.seed.js --force",
    "superadmin:custom": "node ./src/seeders/admin.seed.js --email admin@myapp.com --password mysecurepass",
    "seed:consultation": "node ./src/booking/seed-consultation.js",
    "seed:permissions": "node ./src/permissions/seeders/permissions.seed.js",
    "seed-categories": "node ./src/seeders/categories.seed.js",
    "seed:stores": "node ./src/seeders/stores.seed.js",
    "seed:product": "node ./src/seeders/products.seed.js",
    "seed:roles": "node ./src/permissions/seeders/roles.seed.js"
  },
